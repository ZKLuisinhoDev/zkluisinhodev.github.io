---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="py-32 px-4 bg-white/[0.02]">
  <div class="max-w-6xl mx-auto space-y-24">
    <!-- Bio & Education -->
    <div class="flex flex-col md:flex-row gap-16 items-start">
      <div class="flex-1 space-y-8">
        <div class="inline-flex items-center gap-2 text-blue-400 font-medium">
          <span class="w-12 h-px bg-blue-400"></span>
          {t("nav.about")}
        </div>
        <h2 class="text-3xl md:text-5xl font-bold text-white reveal">
          {t("about.title")} <br />
          <span class="text-gray-500">{t("about.subtitle")}</span>
        </h2>
        <p class="text-gray-400 leading-relaxed text-lg text-pretty reveal">
          {t("about.desc1")}
        </p>
        <p class="text-gray-400 leading-relaxed text-lg text-pretty reveal">
          {t("about.desc2")}
        </p>

        <!-- Idiomas -->
        <div class="space-y-4 pt-4 reveal">
          <h3 class="text-xl font-bold text-white">{t("about.languages")}</h3>
          <div class="flex flex-wrap gap-4">
            <div
              class="px-4 py-2 bg-white/5 border border-white/10 rounded-xl hover:border-blue-500/50 transition-colors"
            >
              <span class="text-blue-400 font-bold">{t("about.lang.es").split(' - ')[0]}</span> - {t("about.lang.es").split(' - ')[1]}
            </div>
            <div
              class="px-4 py-2 bg-white/5 border border-white/10 rounded-xl hover:border-blue-500/50 transition-colors"
            >
              <span class="text-blue-400 font-bold">{t("about.lang.en").split(' - ')[0]}</span> - {t("about.lang.en").split(' - ')[1]}
            </div>
            <div
              class="px-4 py-2 bg-white/5 border border-white/10 rounded-xl hover:border-blue-500/50 transition-colors"
            >
              <span class="text-blue-400 font-bold">{t("about.lang.fr").split(' - ')[0]}</span> - {t("about.lang.fr").split(' - ')[1]}
            </div>
          </div>
        </div>
      </div>

      <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Tarjetas de Educación -->
        <div
          class="reveal p-6 bg-blue-600/10 border border-blue-500/20 rounded-2xl space-y-3 hover:bg-blue-600/20 transition-colors group"
        >
          <div class="text-blue-400 group-hover:scale-110 transition-transform">
            <svg
              class="w-8 h-8"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path d="M12 14l9-5-9-5-9 5 9 5z"></path><path
                d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
              ></path></svg
            >
          </div>
          <h3 class="font-bold text-white">{lang === 'es' ? 'Sistemas' : 'Systems'}</h3>
          <p class="text-sm text-gray-400">Universidad de Nariño</p>
          <span class="text-[10px] uppercase tracking-widest text-blue-300"
            >{lang === 'es' ? 'Grado Ingeniería' : "Engineering Degree"}</span
          >
        </div>

        <div
          class="reveal p-6 bg-purple-600/10 border border-purple-500/20 rounded-2xl space-y-3 hover:bg-purple-600/20 transition-colors group"
        >
          <div
            class="text-purple-400 group-hover:scale-110 transition-transform"
          >
            <svg
              class="w-8 h-8"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path></svg
            >
          </div>
          <h3 class="font-bold text-white">Multimedia</h3>
          <p class="text-sm text-gray-400">SENA</p>
          <span class="text-[10px] uppercase tracking-widest text-purple-300"
            >{lang === 'es' ? 'Técnico Diseño' : 'Design Technician'}</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
